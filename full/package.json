{
  "name": "@appsec/specia",
  "version": "2.3.1",
  "type": "module",
  "description": "Security-aware spec-driven development MCP server",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://gitlab.veritran.net/appsec/specia.git"
  },
  "keywords": [
    "mcp",
    "security",
    "spec-driven-development",
    "ai-agent",
    "appsec",
    "threat-modeling",
    "stride",
    "owasp"
  ],
  "bin": {
    "specia-mcp": "./bin/specia-mcp.js",
    "specia": "./bin/specia-cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "agents",
    "install.sh",
    "install.ps1",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.32",
    "eslint": "^9.25.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.1"
  }
}
